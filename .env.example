# ==========================================
# Speed Doctor Environment Variables
# ==========================================
# Make a copy of this file and rename it to `.env`
# Do NOT commit your `.env` file to version control.

# ------------------------------------------
# Database (Neon serverless PostgreSQL)
# ------------------------------------------
# Get this from your Neon console (https://neon.tech/)
# Make sure to append ?sslmode=require if connecting from a remote environment
DATABASE_URL="postgresql://[user]:[password]@[host]/[dbname]?sslmode=require"

# ------------------------------------------
# Queue & Cache (Upstash Redis)
# ------------------------------------------
# Get this from Upstash Console (https://upstash.com/)
# Important: Ensure the scheme is `rediss://` for secure TLS connection required by BullMQ/Upstash
REDIS_URL="rediss://default:[password]@[endpoint]:6379"

# ------------------------------------------
# AI Engine (OpenRouter)
# ------------------------------------------
# Get this from OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY="sk-or-v1-..."

# ------------------------------------------
# App & Worker Configuration
# ------------------------------------------
# How many headless browsers (Playwright) the worker should run concurrently
# Note: Keep this at 2-5 for local development to avoid memory exhaustion
WORKER_CONCURRENCY=5

# AI batch size — how many issues are sent to OpenRouter in parallel
# Lower this if you hit OpenRouter rate limits
AI_BATCH_SIZE=3

# ------------------------------------------
# API Server Configuration
# ------------------------------------------
# Port the NestJS API listens on (default: 3001)
PORT=3001

# Comma-separated list of allowed CORS origins (your frontend URL)
ALLOWED_ORIGINS=http://localhost:3000

# Max audit requests per IP per minute (default: 10)
RATE_LIMIT_MAX=10

# ------------------------------------------
# Frontend (Next.js)
# ------------------------------------------
# Public URL of the NestJS API (used by the browser to fetch reports)
NEXT_PUBLIC_API_URL=http://localhost:3001
